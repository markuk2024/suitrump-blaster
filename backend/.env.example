# SuiTrump Blaster Backend Environment Variables

# Sui Network Configuration
SUI_NETWORK=https://fullnode.mainnet.sui.io

# Smart Contract Configuration
# Set this to your deployed package ID on Sui blockchain
PACKAGE_ID=your_package_id_here

# AWS S3 Configuration (for data persistence)
# Create an S3 bucket named 'suitrump-blaster-data' or your custom name
S3_BUCKET_NAME=your_bucket_name_here
S3_DATA_KEY=suitrump-blaster/data.json

# Admin Configuration (for reward distribution)
ADMIN_PRIVATE_KEY=your_admin_private_key_here

# Pool Object IDs (Get these from your contract deployment)
DAILY_POOL_ID=0x0
WEEKLY_POOL_ID=0x0
MONTHLY_POOL_ID=0x0

# Dev Fee Configuration
DEV_FEE_PERCENTAGE=2.5
DEV_WALLET_ADDRESS=0x0d32cdae7aa9a25003687dcbfe154c5d13bc51b76fd29116a54276c1f80fd140

# Game Configuration
MAX_SCORE_PER_SECOND=100

# SUITRUMP Token Configuration
SUITRUMP_TOKEN_PACKAGE=0x0
SUITRUMM_TAKEN_MXDU_A=suitrump
SUIE_UMPUTOKAN_NAMTISUITRUMP
POOL_ENTRY_FEE=100000000
